{
  "name": "notra",
  "version": "0.0.2",
  "description": "Command-line interface for the Notra API.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "notra": "./dist/run.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun ./dist/dev.js",
    "start": "bun ./dist/run.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "snapshot:run": "bun ./snapshot/run.ts",
    "snapshot:serve": "bun ./snapshot/serve.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "@oclif/core": "^4.0.33",
    "@oclif/plugin-help": "^6.2.18",
    "@oclif/plugin-not-found": "^3.2.27",
    "@oclif/plugin-warn-if-update-available": "^3.1.21",
    "@usenotra/sdk": "^1.0.6",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "conf": "^13.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  },
  "oclif": {
    "bin": "notra",
    "dirname": "notra",
    "commands": "./src/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-not-found",
      "@oclif/plugin-warn-if-update-available"
    ],
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Sign in to Notra and manage the local API key."
      },
      "config": {
        "description": "Manage local CLI configuration (API key, base URL)."
      },
      "posts": {
        "description": "List, read, update, delete, and generate posts."
      },
      "brands": {
        "description": "Manage brand identities and run brand-identity generation jobs."
      },
      "integrations": {
        "description": "List and manage integrations (GitHub, Linear, Slack)."
      },
      "schedules": {
        "description": "Manage scheduled, automated content generation."
      }
    },
    "warn-if-update-available": {
      "timeoutInDays": 7
    }
  }
}
